# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_relearning
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME="E-Learning System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Security Settings
SESSION_LIFETIME=3600
CSRF_TOKEN_NAME=csrf_token
UPLOAD_MAX_SIZE=10485760

# File Upload Paths
UPLOAD_MATERIALS_PATH=uploads/materials/
UPLOAD_PROFILES_PATH=uploads/profiles/
UPLOAD_DISCUSSIONS_PATH=uploads/discussions/

# Allowed File Extensions
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif
ALLOWED_DOCUMENT_EXTENSIONS=pdf,doc,docx,ppt,pptx