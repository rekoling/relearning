{
    "name": "relearning/e-learning-system",
    "description": "Modern PHP e-learning management system",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Relearning Team",
            "email": "dev@relearning.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.0",
        "twig/twig": "^3.0",
        "symfony/http-foundation": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src",
        "cs-check": "phpcs src",
        "cs-fix": "phpcbf src"
    }
}